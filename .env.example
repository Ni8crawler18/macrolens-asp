# Server
PORT=4022

# --- OKX x402 payment (X Layer, eip155:196) ---
# Create OKX API credentials at https://web3.okx.com/onchainos/dev-portal
# Payment on POST /api/macros ($0.02) is enforced only when
# PAYMENT_ENABLED=true AND all four values below are set; otherwise the
# server runs free (safe default for dev/test/deploys without keys).
PAYMENT_ENABLED=false
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=

# --- AI enrichment (optional) ---
# Setting an Anthropic API key enables Claude-powered estimates for foods the
# local database cannot match. Leave unset to keep the service fully
# deterministic. ENRICH_ENABLED=true forces enrichment on when credentials
# come from elsewhere (e.g. an `ant auth login` profile).
ANTHROPIC_API_KEY=
# ENRICH_ENABLED=true
ENRICH_MODEL=claude-haiku-4-5
