# Server
PORT=4022

# --- x402 payments ---
# Set to "true" to require x402 payment on paid endpoints (/mcp, /api/macros).
# Any other value (or unset) disables payments so local dev needs no wallet.
PAYMENT_ENABLED=false

# Address that receives payments (EVM 0x... address).
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# Price charged per paid call, in USD (x402 "Money" string).
PRICE_PER_CALL=$0.05

# x402 network, e.g. base-sepolia (testnet) or base (mainnet).
X402_NETWORK=base-sepolia

# Optional custom facilitator URL (defaults to the x402.org testnet facilitator).
# X402_FACILITATOR_URL=https://x402.org/facilitator

# --- AI enrichment (optional) ---
# Setting an Anthropic API key enables Claude-powered estimates for foods the
# local database cannot match. Leave unset to keep the service fully
# deterministic. ENRICH_ENABLED=true forces enrichment on when credentials
# come from elsewhere (e.g. an `ant auth login` profile).
ANTHROPIC_API_KEY=
# ENRICH_ENABLED=true
ENRICH_MODEL=claude-haiku-4-5
